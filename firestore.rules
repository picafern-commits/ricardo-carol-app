rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function optionalString(field) {
      return !(request.resource.data.keys().hasAny([field])) || request.resource.data[field] is string || request.resource.data[field] == null;
    }

    function optionalBool(field) {
      return !(request.resource.data.keys().hasAny([field])) || request.resource.data[field] is bool || request.resource.data[field] == null;
    }

    function optionalMap(field) {
      return !(request.resource.data.keys().hasAny([field])) || request.resource.data[field] is map || request.resource.data[field] == null;
    }

    function validCompra() {
      return request.resource.data.keys().hasOnly([
        'name', 'qty', 'category', 'status', 'urgent', 'photoData', 'by', 'byName', 'createdAt', 'doneAt', 'completedByName', 'updatedByName'
      ])
      && request.resource.data.name is string
      && request.resource.data.qty is string
      && request.resource.data.category is string
      && request.resource.data.status in ['pending', 'done']
      && optionalBool('urgent')
      && optionalString('photoData')
      && optionalString('by')
      && optionalString('byName')
      && optionalString('doneAt')
      && optionalString('completedByName')
      && optionalString('updatedByName');
    }

    function validTarefa() {
      return request.resource.data.keys().hasOnly([
        'title', 'due', 'priority', 'status', 'by', 'byName', 'createdAt', 'doneAt', 'completedByName',
        'reminderAt', 'reminderLabel', 'reminderSent', 'reminderSentAt', 'updatedByName'
      ])
      && request.resource.data.title is string
      && request.resource.data.due is string
      && request.resource.data.priority in ['Baixa', 'Normal', 'Alta']
      && request.resource.data.status in ['pending', 'done']
      && optionalString('by')
      && optionalString('byName')
      && optionalString('doneAt')
      && optionalString('completedByName')
      && optionalString('reminderAt')
      && optionalString('reminderLabel')
      && optionalBool('reminderSent')
      && optionalString('updatedByName');
    }

    match /casal/principal/compras/{itemId} {
      allow read, delete: if signedIn();
      allow create, update: if signedIn() && validCompra();
    }

    match /casal/principal/tarefas/{taskId} {
      allow read, delete: if signedIn();
      allow create, update: if signedIn() && validTarefa();
    }

    match /casal/principal/logs/{logId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly(['text', 'type', 'createdAt'])
        && request.resource.data.text is string
        && request.resource.data.type in ['info', 'shop', 'task'];
      allow update, delete: if false;
    }

    match /casal/principal/tokens/{tokenId} {
      allow read, delete: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.keys().hasOnly([
          'token', 'uid', 'profileName', 'notificationPrefs', 'userAgent', 'standalone', 'sw', 'appVersion', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.token is string
        && optionalString('uid')
        && optionalString('profileName')
        && optionalMap('notificationPrefs');
    }
  }
}
