{
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default"
    }
  ],
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "README.md",
      "functions/**",
      "**/.*",
      "**/node_modules/**",
      "**/*.zip"
    ],
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
